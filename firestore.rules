rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 헬퍼 함수: 인증된 사용자 확인
    function isAuthenticated() {
      return request.auth != null;
    }

    // 헬퍼 함수: 자신의 데이터 접근 확인
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 헬퍼 함수: 공유된 데이터 읽기 권한 확인 (최대 2인 공유)
    function hasReadPermission(userId) {
      return isAuthenticated() && (
        request.auth.uid == userId ||
        exists(/databases/$(database)/documents/users/$(userId)/shares/$(request.auth.uid))
      );
    }

    // 헬퍼 함수: 유효한 Todo 데이터 확인
    function isValidTodo(todo) {
      return todo.keys().hasAll(['text', 'completed', 'createdAt']) &&
             todo.text is string &&
             todo.completed is bool &&
             todo.createdAt is timestamp;
    }

    // ==================== users 컬렉션 ====================
    // 컬렉션 전체에 대한 읽기 권한 (이메일 검색용)
    match /users {
      allow read: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);

      // 월간 목표: users/{userId}/monthly/{yearMonth}/todos/{todoId}
      match /monthly/{yearMonth}/todos/{todoId} {
        allow read: if hasReadPermission(userId);
        allow write: if isOwner(userId);
      }

      // 일별 할 일: users/{userId}/daily/{dateKey}/todos/{todoId}
      match /daily/{dateKey}/todos/{todoId} {
        allow read: if hasReadPermission(userId);
        allow write: if isOwner(userId);
      }

      // 공유 목록: users/{userId}/shares/{shareId}
      match /shares/{shareId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) ||
          (resource.data.sharedWithId == request.auth.uid && request.resource.data.status == 'active');
      }
    }

    // ==================== invites 컬렉션 (전역 초대) ====================
    match /invites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if request.auth.uid == resource.data.inviterId || 
                     request.auth.uid == resource.data.inviteeId;
      allow delete: if isOwner(inviteId);
    }
  }
}
